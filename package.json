{
  "name": "watchnest",
  "version": "1.0.0",
  "private": true,
  "description": "WatchNest realtime watch rooms with audio chat.",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server start",
    "lint": "npm --workspaces run lint",
    "check": "node --check server/src/server.js"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
